# ---------------------------------------------------------------------------
# Context Vault environment variables
# Copy to .env.local (or run `pnpm env:sync` / `pnpm bootstrap`).
# NEVER commit real production secrets.
# ---------------------------------------------------------------------------

# Public Supabase config (safe to expose to the browser).
# For local development these default to the well-known Supabase CLI demo JWTs
# (stable across `supabase start`). They are LOCAL ONLY — replace them for any
# hosted / preview / production project.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Server-only Supabase service role key. NEVER expose to the browser.
# Local demo JWT below — LOCAL ONLY, never use in production.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# ---------------------------------------------------------------------------
# AI providers (server-only, never exposed to the browser)
# ---------------------------------------------------------------------------

# OpenRouter API key for multi-model chat AND structured memory extraction.
# If empty, chat uses a local mock model and extraction falls back to
# deterministic heuristics so the app remains fully demoable offline.
OPENROUTER_API_KEY=
# Optional OpenRouter overrides.
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_SITE_URL=http://localhost:3000
# Model used for structured memory extraction (cortaix id or legacy provider id).
# EXTRACTION_MODEL=openai.gpt-4o-mini
# Max time (ms) for a single extraction call before falling back to heuristics.
# EXTRACTION_TIMEOUT_MS=8000

# Direct provider keys (optional). OpenRouter remains the default platform path.
# Comma-separated pool for rate-limit headroom:
# OPENROUTER_API_KEYS=sk-or-1,sk-or-2
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=
# GROQ_API_KEY=

# Required in production to encrypt BYOK provider keys (AES-256-GCM).
# Locally, if unset, falls back to SUPABASE_SERVICE_ROLE_KEY for convenience.
# Never reuse the service role key in production. Store in your secret manager
# (Vercel/Doppler/etc). To rotate: dual-read old+new keys in a migration window,
# re-encrypt rows, then drop the old key (see README → BYOK encryption).
# BYOK_ENCRYPTION_KEY=

# ---------------------------------------------------------------------------
# Billing (Stripe) — Cortaix owns the customer relationship (EUR / Free·Lite·Pro)
# ---------------------------------------------------------------------------
# Commercial mode: disabled | demo | live
# - demo (default locally): catalog + Free usage; never creates Stripe Checkout
# - disabled (default in production if unset): hide/disable commercial actions
# - live: Checkout / Portal only when live-readiness passes (Stripe secret,
#   webhook secret, all four price IDs, NEXT_PUBLIC_APP_URL, webhook health)
# Use Stripe *test* secrets (sk_test_*) first. sk_live_* also requires:
# STRIPE_ALLOW_LIVE_KEYS=1
# COMMERCIAL_MODE=demo
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_LITE_MONTHLY=
# STRIPE_PRICE_LITE_ANNUAL=
# STRIPE_PRICE_PRO_MONTHLY=
# STRIPE_PRICE_PRO_ANNUAL=
# Optional founding Pro coupon (maps to ~€25/mo promotional price)
# STRIPE_COUPON_PRO_FOUNDING=
# Optional Frontier boost pack (not shown on storefront by default)
# STRIPE_PRICE_PACK_FRONTIER_BOOST=
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# STRIPE_ALLOW_LIVE_KEYS=
# Configure Stripe Tax + Customer Portal in the Dashboard before live launch.
# Dev top-up is available only in COMMERCIAL_MODE=demo when NODE_ENV !== production.
# There is no production override.
#
# Unfinished feature flags (default off). Set to 1/true/on to enable.
# FEATURE_VOICE=
# FEATURE_AUTO_TOPUP=
# FEATURE_SPEND_CAP_ENFORCEMENT=
# FEATURE_WORKSPACE_BUDGETS=
# FEATURE_DAILY_FAIR_USE=
# FEATURE_CREDIT_PACK_STOREFRONT=

# Optional deployment identifier surfaced on /admin/system and /api/status.
# On Vercel, VERCEL_DEPLOYMENT_ID / VERCEL_GIT_COMMIT_SHA are used as fallbacks.
# DEPLOYMENT_ID=

# Embedding provider: "local" (default, offline, deterministic) or "openai".
EMBEDDING_PROVIDER=local
# Used only when EMBEDDING_PROVIDER=openai (via OpenAI-compatible endpoint).
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---------------------------------------------------------------------------
# Memory provider: "supabase" (default) or "mem0" (pluggable, see lib/memory)
# ---------------------------------------------------------------------------
MEMORY_PROVIDER=supabase
MEM0_API_KEY=
# Optional Mem0 API base URL (defaults to https://api.mem0.ai).
# MEM0_API_BASE_URL=https://api.mem0.ai

# ---------------------------------------------------------------------------
# Google Sign-In (Supabase Auth external provider).
# Create an OAuth 2.0 Client (Web) in Google Cloud and paste the values here.
# For LOCAL dev the Supabase CLI reads these when running `supabase start`
# (leave empty to keep Google disabled locally). In hosted Supabase, configure
# the provider in the dashboard instead of these vars.
#   Authorized redirect URI (local):  http://127.0.0.1:54321/auth/v1/callback
#   Authorized redirect URI (hosted): https://<project-ref>.supabase.co/auth/v1/callback
# ---------------------------------------------------------------------------
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
