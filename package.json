{
  "name": "context-vault",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "CV_REQUIRE_SUPABASE=1 vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --exclude 'tests/**/*.integration.test.ts' --exclude tests/memory.test.ts",
    "test:integration": "CV_INTEGRATION=1 vitest run tests/memory.test.ts tests/stripe-webhook.integration.test.ts tests/admin-auth.integration.test.ts tests/admin-entitlements.integration.test.ts tests/admin-config-rls.integration.test.ts tests/plan-config.integration.test.ts tests/plan-editor.integration.test.ts tests/provider-ops.integration.test.ts tests/promotions.integration.test.ts tests/stripe-lifecycle.integration.test.ts",
    "check": "pnpm lint && pnpm typecheck && pnpm test:unit",
    "check:full": "pnpm check && pnpm test:integration",
    "env:sync": "node --import tsx scripts/env-sync.ts",
    "health": "node --import tsx scripts/doctor.ts",
    "bootstrap": "node --import tsx scripts/setup.ts",
    "db:start": "supabase start",
    "db:reset": "supabase db reset && pnpm db:seed",
    "db:seed": "node --import tsx scripts/seed-runner.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.45.4",
    "clsx": "^2.1.1",
    "lucide-react": "^0.454.0",
    "next": "14.2.15",
    "pdf-parse": "^1.1.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "stripe": "^22.3.2",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "14.2.15",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  }
}
